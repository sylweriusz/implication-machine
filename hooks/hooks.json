          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/zen-reconcile-gate.js\"",
            "timeout": 10,
            "statusMessage": "IMPLICATIONâ†’MACHINE reconcile gate..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
